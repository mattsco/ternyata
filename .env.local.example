# ─── Supabase (non requis pour la v1 seed ; nécessaire au pipeline quotidien) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Plugin TRMNL (endpoint /api/term protégé par token) ──────────────────────
# openssl rand -hex 32  → à renseigner aussi dans le custom field du plugin TRMNL
TRMNL_API_TOKEN=

# ─── Pipeline quotidien (v2 : tirage → TMDB → synopsis LLM via cron Vercel) ────
TMDB_API_KEY=
ANTHROPIC_API_KEY=
CRON_SECRET=
